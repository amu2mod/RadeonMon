#include "winver.h"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @APP_VERSION_RC@
 PRODUCTVERSION @APP_VERSION_RC@
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "FileDescription", "RadeonMon - GPU Monitoring tool"
            VALUE "FileVersion", "@APP_VERSION_STR@"
            VALUE "InternalName", "RadeonMon.exe"
            VALUE "OriginalFilename", "RadeonMon.exe"
            VALUE "ProductName", "RadeonMon"
            VALUE "ProductVersion", "@APP_VERSION_STR@"
            VALUE "LegalCopyright", "Copyright (C) Amu"
            VALUE "Comments", "Hardware monitoring utility"
        END
    END

    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END