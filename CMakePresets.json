{
    "version": 3,
    "configurePresets": [
        {
            "name": "Debug",
            "displayName": "MSVC + Ninja x64 (Debug)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_COMPILER": "cl"
            }
        },
        {
            "name": "MSVC + Ninja x64 (Debug-Local)",
            "inherits": "Debug",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "ENABLE_LOCALFILES": "ON",
                "ENABLE_GDIDRAW": "OFF",
                "ENABLE_TESTMODE": "OFF"
            }
        },
        {
            "name": "Release",
            "displayName": "MSVC + Ninja x64 (Release)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_COMPILER": "cl"
            }
        }
    ]
}